<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/editItem.css">
    <title>Edit item <%= item.name %></title>
</head>
<body>
    <%- include("./partials/header" , {selected:""}) %>
    <main>
        <div>
            <form id="deleteItem" style="visibility: hidden; position: absolute;" action="/item/<%= item.id %>/delete" method="post">
            <label >
            <input type="hidden" name="password" id="deletepass">
        </label>
            </form>
            <img src="<%= item.imageurl %>" alt="<%= item.name %>">
            <form id="editItem" action="/item/<%= item.id %>" method="post">
                <label >
                    TITLE:
                    <br>
                    <input name="name" type="text" required pattern="[\w\s]{3,255}" value="<%= item.name %>">
                </label>
                <label >
                    PRICE: <br>
                    <input step="0.01" min="0" name="price" type="number" required value="<%= item.price %>">
                </label>
                <label>
                    STOCK: <br>
                    <input min="0" type="number" name="stock" value="<%= item.quantity %>">
                </label>
                <label>
                    IMAGE URL: <br>
                    <input id="url" type="url" name="imageURL" value="<%= item.imageurl %>">
                    <button id="urlbtn">
                    PREVIEW IMAGE
                    </button>
                </label>
                <label>
                    CATEGORY: <br>
            <select name="category">
                <% const s = item.categoryid; %>
            
                <option value="1" <%= s === 1 ? "selected" : "" %>>Electric Guitars</option>
                <option value="2" <%= s === 2 ? "selected" : "" %>>Amplifiers</option>
                <option value="3" <%= s === 3 ? "selected" : "" %>>Effects Pedals</option>
                <option value="4" <%= s === 4 ? "selected" : "" %>>Cables</option>
                <option value="5" <%= s === 5 ? "selected" : "" %>>Accessories</option>
            </select>
                </label>
                <label>
                    DESCRIPTION: <br>
                    <textarea name="description" ><%= item.description%></textarea>
                </label>
            <label style="visibility: hidden; position: absolute;">
            <input type="hidden" name="password" id="editpass">
        </label>
            </form>
        </div>
        <label >
            ITEM PASSWORD: <br>
            <h4><%= error %></h4>
            <input id="password" required type="password" name="password">
        </label>
        <div>
                <button type="submit" form="editItem">EDIT</button>
                <button type="submit" form="deleteItem">DELETE</button>
        </div>
    </main>
    <%- include("./partials/footer",{darkMode:darkMode}) %>
</body>
<script>
    const btn = document.querySelector("#urlbtn")
    const img = document.querySelector("img")
    btn.addEventListener("click" , (e) => {
        e.preventDefault();
        const input = document.querySelector("#url")
        img.setAttribute("src",input.value) 
    })

    const password = document.getElementById("password");

    password.addEventListener("input", () => {
    document.getElementById("editpass").value = password.value;
    document.getElementById("deletepass").value = password.value;
});
</script>
</html>